{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/ai-response",
      "dest": "server.js"
    },
    {
      "src": "/generate-image",
      "dest": "server.js"
    },
    {
      "src": "/",
      "dest": "index.html"
    }
  ]
}